rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /fcmTokens/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn();
      allow update: if isGroupMember(groupId);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update: if isGroupMember(groupId);
        allow delete: if isGroupAdmin(groupId);
      }

      match /transactions/{transactionId} {
        allow read, create: if isGroupMember(groupId);
        allow update, delete: if isGroupAdmin(groupId);
      }

      match /activity/{activityId} {
        allow read, create: if isGroupMember(groupId);
      }
    }

    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isOwner(userId);
    }

    match /paymentProofs/{proofId} {
      allow read: if isSignedIn() && isGroupMember(resource.data.groupId);
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.uploadedBy &&
        isGroupMember(request.resource.data.groupId);
      allow update: if isSignedIn() &&
        isGroupAdmin(resource.data.groupId) &&
        request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'reviewedBy', 'reviewNote', 'reviewedAt']);
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.uploadedBy ||
        isGroupAdmin(resource.data.groupId)
      );
    }

    match /userAchievements/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
